{
  "name": "@txline-kit/client",
  "version": "0.1.0",
  "description": "TypeScript client for the TxLINE sports data API: auth, typed REST, self-healing SSE streams, and Merkle-proof helpers for the txoracle Solana program",
  "type": "module",
  "author": "addargBackup (https://x.com/addarg7)",
  "license": "MIT",
  "keywords": ["txline", "txodds", "sports-data", "soccer", "solana", "merkle-proof", "world-cup"],
  "repository": { "type": "git", "url": "git+https://github.com/addargBackup/txline-kit.git", "directory": "packages/client" },
  "homepage": "https://github.com/addargBackup/txline-kit#readme",
  "bugs": "https://github.com/addargBackup/txline-kit/issues",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./proofs": {
      "types": "./dist/proofs.d.ts",
      "default": "./dist/proofs.js"
    }
  },
  "files": ["dist", "idl"],
  "scripts": {
    "build": "tsc -b"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.98.0",
    "@txline-kit/constants": "workspace:*",
    "bn.js": "^5.2.1",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.6"
  }
}
